      "@id": "aws:port",
      "@type": "xsd:string"
    },
    "virtualNode": {
      "@id": "aws:virtualNode",
      "@type": "xsd:string"
    },
    "weight": {
      "@id": "aws:weight",
      "@type": "xsd:string"
    }
  }
}