      "@id": "aws:virtualRouterName",
      "@type": "xsd:string"
    },
    "arn": {
      "@id": "aws:arn",
      "@type": "xsd:string"
    },
    "createdAt": {
      "@id": "aws:createdAt",
      "@type": "xsd:string"
    },
    "lastUpdatedAt": {
      "@id": "aws:lastUpdatedAt",
      "@type": "xsd:string"
    },
    "meshOwner": {
