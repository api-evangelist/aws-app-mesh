    },
    "httpRoute": {
      "@id": "aws:httpRoute",
      "@type": "xsd:string"
    },
    "priority": {
      "@id": "aws:priority",
      "@type": "xsd:string"
    },
    "tcpRoute": {
      "@id": "aws:tcpRoute",
      "@type": "xsd:string"
    },
    "meshName": {
      "@id": "aws:meshName",
      "@type": "xsd:string"
    },
    "metadata": {
      "@id": "aws:metadata",
      "@type": "xsd:string"
    },
    "routeName": {
      "@id": "aws:routeName",
      "@type": "xsd:string"
    },
